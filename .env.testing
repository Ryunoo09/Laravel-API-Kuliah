APP_NAME="Laravel Testing"
APP_ENV=testing
APP_KEY=base64:FxWSEn0NKSaATnX3A3EpqucjClqdhn0hugrFtxSq6Rc=
APP_DEBUG=true
APP_URL=http://localhost

# ──────────────────────────────────────────
#  DATABASE — SQLite in-memory (super cepat)
# ──────────────────────────────────────────
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

# ──────────────────────────────────────────
#  CACHE, QUEUE, SESSION — semua in-memory
# ──────────────────────────────────────────
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# ──────────────────────────────────────────
#  HASHING — 4 rounds agar bcrypt lebih cepat
# ──────────────────────────────────────────
BCRYPT_ROUNDS=4

# ──────────────────────────────────────────
#  MAIL — array driver (tidak benar-benar kirim)
# ──────────────────────────────────────────
MAIL_MAILER=array

# ──────────────────────────────────────────
#  SANCTUM
# ──────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost
